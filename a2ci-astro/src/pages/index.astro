---
import BaseLayout from '../layouts/BaseLayout.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/ContactSection.astro';
import ContactSection from '../components/ContactSection.astro';
import TeamCarousel from '../components/TeamCarousel.astro';
---

<BaseLayout title="A2CI Prévention Incendie – Coordination SSI, Audit, Conseil, Formation" bodyClass="bg-[#0b0b0b] text-white">

  <!-- Hero Section -->
  <section class="relative w-full overflow-hidden bg-black py-20 lg:py-32 flex flex-col justify-center min-h-[700px] lg:min-h-[800px]">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero_fire_night.jpg" alt="Expertise sécurité incendie A2Ci" class="h-full w-full object-cover opacity-60" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-black/20"></div>
    </div>

    <div id="particles-js" class="absolute inset-0 z-0 opacity-30"></div>

    <div class="relative z-10 mx-auto max-w-content px-4 flex flex-col justify-center">
      <div class="max-w-3xl scroll-reveal" data-animate="fade-right" style="--reveal-delay: 120ms;">
        <h1 class="mb-6 font-heading text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-7xl">
          Maîtriser le risque incendie,<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">garantir la sécurité.</span>
        </h1>
        <p class="mb-10 max-w-2xl text-lg text-gray-200 leading-relaxed">Bureau d'études spécialisé en sécurité incendie. Nous accompagnons les ERP, IGH et sites industriels dans l'audit, la coordination SSI et la conformité réglementaire.</p>

        <div class="flex flex-wrap items-center gap-6 mb-12">
          <div class="flex flex-wrap items-center gap-4">
            <a href="#contact" class="inline-flex items-center justify-center rounded-md bg-a2ci-red px-8 py-4 text-base font-semibold text-white transition duration-300 hover:bg-[#960606] hover:shadow-lg hover:shadow-[#C00000]/20">Demander une étude</a>
            <a href="#expertises" class="inline-flex items-center justify-center rounded-md border border-white/30 bg-white/5 px-8 py-4 text-base font-semibold text-white backdrop-blur-sm transition duration-300 hover:bg-white/10">Nos expertises</a>
          </div>
          <div class="flex items-center gap-3 sm:border-l sm:border-white/20 sm:pl-6">
            <div class="flex flex-col">
              <div class="flex gap-1 text-yellow-400 text-sm">
                {Array.from({length: 5}).map(() => (
                  <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
              <div class="mt-1 flex items-center gap-1 text-xs font-medium text-gray-300">
                <span class="text-white font-bold text-sm">4.9/5</span> sur Google
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3 Piliers -->
  <section class="bg-gray-50 pt-0 pb-16 overflow-hidden">
    <div class="container-custom">
      <div class="flex justify-center -mt-12 mb-6">
        <img src="/images/medaille_20ans.png" alt="20 Ans A2Ci" class="w-20 md:w-24 h-auto opacity-95 transition-opacity hover:opacity-100" />
      </div>
      <div class="text-center mb-16 scroll-reveal">
        <div class="h2-bar justify-center">
          <span></span>
          <h2 class="section-title mb-0">Une approche globale & <span class="text-a2ci-red">technique</span></h2>
          <span></span>
        </div>
      </div>
      <div class="grid gap-12 md:grid-cols-3">
        {[
          { icon: "/images/A2CI_Audit.svg", title: "AUDIT", desc: "Analyse technique et réglementaire complète de vos installations existantes pour garantir leur performance et leur conformité.", href: "#audit-conseil" },
          { icon: "/images/A2CI_Coordination%20SSI.svg", title: "COORDINATION SSI / RUS", desc: "Accompagnement dans la conception, le suivi de chantier et la coordination du Système de Sécurité Incendie.", href: "#bet-ssi" },
          { icon: "/images/A2CI_Formation.svg", title: "FORMATION", desc: "Programmes pédagogiques sur-mesure pour maîtriser les risques incendie et les gestes qui sauvent.", href: "#formations" },
        ].map((item) => (
          <a href={item.href} class="group text-center scroll-reveal">
            <div class="mb-6">
              <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto border border-gray-100 shadow-sm transition-all group-hover:border-a2ci-red group-hover:shadow-md">
                <img src={item.icon} alt={item.title} class="h-12 w-12" />
              </div>
            </div>
            <h3 class="font-heading text-xl font-bold text-gray-900 mb-3 uppercase tracking-tight group-hover:text-a2ci-red transition-colors">{item.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- À propos -->
  <section id="apropos" class="bg-gray-50 overflow-hidden">
    <div class="relative z-10 mx-auto max-w-content px-4 py-24">
      <div class="section-custom">
        <div class="section-img">
          <div class="img-wrapper">
            <img src="https://images.unsplash.com/photo-1664575602276-acd073f104c1?q=80&w=1000&auto=format&fit=crop" alt="Bureau A2CI" />
          </div>
        </div>
        <div class="section-text">
          <div class="h2-bar">
            <span></span>
            <h2 class="section-title mb-6">Votre partenaire incendie dans le <span class="text-a2ci-red">Grand Sud-Ouest</span>.</h2>
          </div>
          <div class="space-y-6 text-gray-600 leading-relaxed">
            <p>Fondée sur une conviction forte : la <strong>sécurité incendie</strong> ne doit pas être une contrainte subie, mais une <strong>stratégie maîtrisée</strong>. Depuis près de deux décennies, <strong>A2CI Prévention Incendie</strong> accompagne les <strong>maîtres d'ouvrage</strong> et les <strong>gestionnaires</strong> dans la complexité des <strong>normes</strong> (<strong>ERP</strong>, <strong>IGH</strong>, <strong>Code du Travail</strong>).</p>
            <p>Implantés à <strong>Mazères (33)</strong>, nous revendiquons notre <strong>indépendance</strong> et notre <strong>proximité</strong>. Contrairement aux grands groupes standardisés, nous apportons une <strong>réponse sur-mesure</strong>, pragmatique et économiquement réaliste à chaque dossier.</p>
          </div>
          <div class="mt-10 grid grid-cols-2 gap-6 border-t border-gray-100 pt-8">
            <div>
              <div class="mb-2 flex items-center gap-2 text-a2ci-red font-heading font-bold uppercase tracking-tight text-sm">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                Indépendance
              </div>
              <p class="text-xs text-gray-500">Un conseil neutre et objectif, sans conflit d'intérêt.</p>
            </div>
            <div>
              <div class="mb-2 flex items-center gap-2 text-a2ci-red font-heading font-bold uppercase tracking-tight text-sm">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                Expertise Terrain
              </div>
              <p class="text-xs text-gray-500">Une équipe issue du milieu opérationnel.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Audit & Conseil -->
  <section id="audit-conseil" class="bg-gray-50 overflow-hidden border-t border-gray-100">
    <div class="container-custom">
      <div class="section-custom reverse">
        <div class="section-img">
          <div class="img-wrapper">
            <img src="/images/Analyse du contexte(audit&conseil).png" alt="Audit & Conseil" class="aspect-[16/10] object-cover w-full" />
          </div>
        </div>
        <div class="section-text">
          <div class="h2-bar"><span></span><h2 class="section-title mb-6">Notre expertise <span class="text-a2ci-red">audit & conseil</span></h2></div>
          <div class="space-y-6 text-gray-600 leading-relaxed">
            <p>Spécialiste de l'<strong>audit technique</strong> et <strong>réglementaire</strong>, A2CI analyse vos <strong>installations existantes</strong> pour garantir leur <strong>conformité</strong> et leur <strong>performance</strong>.</p>
            <p>Nos experts réalisent des <strong>diagnostics complets</strong>, des <strong>tests de fonctionnement</strong> du <strong>SSI</strong> et vous proposent des <strong>solutions correctives</strong> pragmatiques. Une approche <strong>indépendante</strong> pour une <strong>sécurité incendie</strong> maîtrisée et durable.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bureau d'études SSI -->
  <section id="bet-ssi" class="bg-gray-50 overflow-hidden border-t border-gray-100">
    <div class="container-custom">
      <div class="section-custom">
        <div class="section-img">
          <div class="img-wrapper">
            <img src="/images/Phase Etude(BET&AMO).png" alt="Bureau d'études SSI" class="aspect-[16/10] object-cover w-full" />
          </div>
        </div>
        <div class="section-text">
          <div class="h2-bar"><span></span><h2 class="section-title mb-6">Bureau d'études <span class="text-a2ci-red">ingénierie SSI</span></h2></div>
          <div class="space-y-6 text-gray-600 leading-relaxed">
            <p>A2CI intervient en tant que <strong>Bureau d'Études Techniques</strong> et <strong>Assistance à Maîtrise d'Ouvrage (AMO)</strong> pour la <strong>conception</strong>, le <strong>suivi</strong> et la <strong>réception</strong> de vos <strong>Systèmes de Sécurité Incendie</strong>.</p>
            <p>Nous vous accompagnons de la <strong>phase étude</strong> (<strong>DCE</strong>, <strong>analyse des offres</strong>) à la <strong>phase réalisation</strong> jusqu'à la <strong>réception finale</strong> des installations, garantissant une <strong>cohérence technique et réglementaire</strong> tout au long de votre projet.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Secteurs d'intervention -->
  <section id="secteurs" class="relative w-full bg-gray-200 py-24 overflow-hidden">
    <div class="container-custom relative z-10 !py-24">
      <div class="mb-16 max-w-3xl text-left">
        <div class="h2-bar"><span></span><h2 class="section-title !text-gray-900 mb-6">Une expertise adaptée à<br />chaque typologie de <span class="text-a2ci-red">bâtiment.</span></h2></div>
        <p class="text-gray-600 sm:text-lg leading-relaxed">Des EHPAD aux sites industriels classés, A2Ci maîtrise les spécificités réglementaires (Code du Travail, CCH, ICPE) propres à chaque structure.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { href: "/erp", icon: "/images/A2CI_Établissements recevant du public (ERP).svg", title: "ERP", desc: "Commerces, administrations, écoles. Catégories 1 à 5." },
          { href: "/igh", icon: "/images/A2CI_Immeubles de Grande Hauteur (IGH).svg", title: "IGH", desc: "Immeubles de Grande Hauteur (habitation ou bureaux)." },
          { href: "/sante-soins", icon: "/images/A2CI_Hôpitaux, établissements de soins, établissements scolaires.svg", title: "Santé & Soins", desc: "Hôpitaux, Cliniques, EHPAD. Gestion du transfert horizontal." },
          { href: "/industries", icon: "/images/A2CI_Sites industriels et de production.svg", title: "Industries", desc: "Sites de production, stockage et logistique." },
          { href: "/tertiaire-ert", icon: "/images/A2CI_Établissements recevant des travailleurs (ERT).svg", title: "Tertiaire / ERT", desc: "Immeubles de bureaux non ouverts au public." },
          { href: "/habitation", icon: "/images/A2CI_Habitations collectives & résidences.svg", title: "Habitation", desc: "Copropriétés, bailleurs sociaux et syndics." },
          { href: "/culture-loisirs", icon: "/images/A2CI_Bâtiments communaux et collectivités.svg", title: "Culture & Loisirs", desc: "Salles de spectacle, musées, équipements sportifs." },
          { href: "/sieges-sociaux", icon: "/images/A2CI_Bureaux, sièges sociaux et centres d'affaires.svg", title: "Siège sociaux", desc: "Bureaux, sièges sociaux centres d'affaires." },
        ].map((sector) => (
          <a href={sector.href} class="relative flex flex-col justify-between overflow-hidden rounded-xl bg-white border border-gray-100 p-6">
            <div>
              <div class="flex items-center gap-5 mb-5">
                <div class="p-3 bg-gray-50 rounded-lg shrink-0 border border-gray-100">
                  <img src={sector.icon} alt={sector.title} class="h-12 w-12" />
                </div>
                <h3 class="font-heading text-lg font-bold text-gray-900 leading-tight">{sector.title}</h3>
              </div>
              <p class="text-sm text-gray-600 mb-6 leading-relaxed">{sector.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Formations -->
  <section id="formations" class="bg-gray-50 relative overflow-hidden">
    <div class="container-custom">
      <div class="mb-16 flex flex-col md:flex-row md:items-end md:justify-between gap-8 border-b border-gray-100 pb-12">
        <div class="max-w-3xl relative">
          <div class="flex items-start gap-6">
            <img src="/images/A2CI_Formation.svg" alt="Formations" class="hidden sm:block h-20 w-20 opacity-90" />
            <div>
              <div class="h2-bar"><span></span><h2 class="section-title mb-6">Former vos équipes pour <span class="text-a2ci-red">sauver des vies</span>.</h2></div>
              <p class="text-lg text-gray-600 leading-relaxed max-w-2xl">Transformez vos obligations réglementaires en compétences réelles. Nos formateurs sont des experts de terrain (pompiers, préventionnistes).</p>
            </div>
          </div>
        </div>
        <div class="shrink-0 flex flex-col items-center gap-4">
          <a href="/formations" class="inline-flex items-center justify-center rounded-md border border-gray-200 bg-white px-6 py-3 text-sm font-semibold text-gray-900 transition hover:text-a2ci-red shadow-sm group">
            <span>Voir le catalogue</span>
            <svg class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </a>
          <div class="flex flex-col items-center gap-2 border border-gray-200 rounded-xl bg-white px-4 py-3 shadow-sm">
            <img src="/images/qualiopi.png" alt="Certification Qualiopi" class="h-14 w-auto object-contain" />
            <p class="text-[10px] text-gray-500 text-center leading-tight max-w-[180px]">La Certification Qualité a été délivrée au titre de la catégorie d'action suivante :</p>
          </div>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mb-16">
        {[
          { href: "/formations-incendie", icon: "/images/A2CI_formation-incendie-et-evacuation.svg", title: "Incendie & Évacuation", sub: "Les fondamentaux de la sécurité.", items: ["Équipier de Première Intervention (EPI)", "Exercices d'évacuation grandeur nature", "Coordination & Sécurité SSI"] },
          { href: "/formations-secourisme", icon: "/images/A2CI_secourisme-sst.svg", title: "Secourisme (SST)", sub: "Gestes qui sauvent.", items: ["Sauveteur Secouriste du Travail (Initial)", "Recyclage MAC SST (Actualisation des compétences)", "Utilisation du Défibrillateur (DAE)"] },
          { href: "/formations-incendie", icon: "/images/A2CI_moyens-specifiques.svg", title: "Moyens Spécifiques", sub: "Maîtrise technique avancée.", items: ["Port de l'Appareil Respiratoire (ARI)", "Manipulation des RIA (Robinets Incendie)", "Formation Guide-file / Serre-file"] },
        ].map((cat) => (
          <a href={cat.href} class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl border border-gray-100">
            <div>
              <div class="flex items-center gap-5 mb-6">
                <div class="p-4 bg-gray-50 rounded-lg transition-all shrink-0">
                  <img src={cat.icon} alt={cat.title} class="h-20 w-20 opacity-80 group-hover:opacity-100 transition-opacity" />
                </div>
                <div>
                  <h3 class="font-heading text-xl font-extrabold text-gray-900 leading-tight">{cat.title}</h3>
                  <p class="text-sm text-gray-500 mt-1">{cat.sub}</p>
                </div>
              </div>
              <ul class="premium-list space-y-3 text-sm text-gray-700 mb-8">
                {cat.items.map((item) => <li><span>{item}</span></li>)}
              </ul>
            </div>
          </a>
        ))}
      </div>

      <!-- Centre de formation -->
      <div class="relative overflow-hidden rounded-2xl bg-black border border-white/10 px-8 py-12 shadow-2xl bg-tech-grid">
        <div class="absolute bottom-0 left-0 h-40 w-40 bg-a2ci-red opacity-20 blur-[80px] pointer-events-none"></div>
        <div class="absolute top-0 right-0 h-40 w-40 bg-white opacity-5 blur-[80px] pointer-events-none"></div>
        <div class="relative z-10 flex flex-col md:flex-row md:items-center md:justify-between gap-8">
          <div class="max-w-2xl">
            <h3 class="font-heading text-2xl font-bold text-white sm:text-3xl mb-4">Centre de formation agréé à Mazères</h3>
            <p class="text-gray-400 text-lg leading-relaxed">Nous disposons de nos propres infrastructures : salle pédagogique et <span class="text-white font-semibold decoration-a2ci-red decoration-2 underline underline-offset-4">aire de feu extérieure</span> pour les mises en situation réelle sur feux réels.</p>
          </div>
          <div class="shrink-0">
            <a href="#contact" class="group inline-flex items-center justify-center gap-2 rounded-lg bg-a2ci-red px-8 py-4 text-sm font-bold text-white transition-all hover:bg-[#960606] hover:shadow-lg hover:shadow-[#C00000]/20">
              Demander un devis
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Méthode A2Ci -->
  <section class="relative w-full bg-gray-200 py-0 overflow-hidden">
    <div class="relative z-10 container-custom">
      <div class="mb-24 text-center">
        <div class="h2-bar justify-center">
          <span></span>
          <h2 class="section-title !text-gray-900 mb-0">La Méthode <span class="text-a2ci-red">A2Ci</span></h2>
          <span></span>
        </div>
      </div>

      <div class="relative">
        <div class="absolute left-4 md:left-1/2 top-0 h-full w-[2px] -translate-x-1/2 bg-gradient-to-b from-transparent via-[#C00000]/60 to-transparent shadow-[0_0_15px_rgba(192,0,0,0.4)]"></div>

        {[
          { num: "01", title: "Diagnostiquer & Cadrer", desc: "Audit technique et réglementaire pour définir une trajectoire de travaux réaliste. Nous identifions les écarts critiques dès le départ.", image: "https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?q=80&w=1000&auto=format&fit=crop", side: "left" },
          { num: "02", title: "Concevoir & Orchestrer", desc: "Coordination SSI, ingénierie de désenfumage et pilotage. Nous sommes le chef d'orchestre de vos prestataires jusqu'à la réception.", image: "https://images.unsplash.com/photo-1581092921461-eab62e97a780?q=80&w=1000&auto=format&fit=crop", side: "right" },
          { num: "03", title: "Conseiller & Sécuriser (RUS)", desc: "Missions de Responsable Unique de Sécurité (RUS) et préparation des commissions. A2CI agit comme conseiller et coordinateur et ne dispose pas de pouvoir décisionnaire financier.", image: "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?q=80&w=1000&auto=format&fit=crop", side: "left" },
        ].map((step, i) => (
          <div class:list={["relative flex flex-col md:flex-row items-center justify-between w-full group min-h-[250px]", i < 2 ? "mb-32" : ""]}>
            {step.side === "left" ? (
              <>
                <div class="order-2 md:order-1 w-full md:w-5/12 pl-12 md:pl-0 md:text-right md:pr-24 relative z-20">
                  <h3 class="text-3xl font-extrabold text-gray-900 mb-4 group-hover:text-a2ci-red transition-colors duration-300 font-heading">{step.title}</h3>
                  <p class="text-gray-600 text-lg leading-relaxed group-hover:text-gray-700 transition-colors duration-300">{step.desc}</p>
                </div>
                <div class="absolute left-4 md:left-1/2 -translate-x-1/2 flex items-center justify-center order-1 md:order-2 z-20">
                  <div class="relative flex h-14 w-14 items-center justify-center rounded-full bg-black border border-[#C00000]/50 shadow-[0_0_20px_rgba(192,0,0,0.3)] transition-all duration-500 group-hover:border-[#C00000] group-hover:shadow-[0_0_40px_rgba(192,0,0,0.8)] bg-gradient-to-br from-black to-[#C00000]/30">
                    <span class="font-bold text-white text-lg">{step.num}</span>
                  </div>
                </div>
                <div class="hidden md:block w-5/12 order-3 relative h-full">
                  <div class="absolute top-1/2 -translate-y-1/2 left-8 right-0 h-[320px] lg:h-[380px] pointer-events-none">
                    <div class="w-full h-full overflow-hidden rounded-[3rem] border-2 border-[#C00000]/60 shadow-[0_0_30px_rgba(192,0,0,0.3)] animate-float-slow transform rotate-2 transition-all duration-700 group-hover:border-[#C00000] group-hover:shadow-[0_0_50px_rgba(192,0,0,0.7)]">
                      <img src={step.image} alt={step.title} class="w-full h-full object-cover transition-all duration-1000 scale-105 group-hover:scale-100" />
                      <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-black/20"></div>
                    </div>
                  </div>
                </div>
              </>
            ) : (
              <>
                <div class="hidden md:block w-5/12 order-1 relative h-full">
                  <div class="absolute top-1/2 -translate-y-1/2 right-8 left-0 h-[320px] lg:h-[380px] pointer-events-none">
                    <div class="w-full h-full overflow-hidden rounded-[3rem] border-2 border-red-600/60 shadow-[0_0_30px_rgba(220,38,38,0.3)] animate-float-slower transform -rotate-2 transition-all duration-700 group-hover:border-[#C00000] group-hover:shadow-[0_0_50px_rgba(220,38,38,0.7)]">
                      <img src={step.image} alt={step.title} class="w-full h-full object-cover transition-all duration-1000 scale-105 group-hover:scale-100" />
                      <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-black/20"></div>
                    </div>
                  </div>
                </div>
                <div class="absolute left-4 md:left-1/2 -translate-x-1/2 flex items-center justify-center order-1 md:order-2 z-20">
                  <div class="relative flex h-14 w-14 items-center justify-center rounded-full bg-black border border-[#C00000]/50 shadow-[0_0_20px_rgba(192,0,0,0.3)] transition-all duration-500 group-hover:border-[#C00000] group-hover:shadow-[0_0_40px_rgba(192,0,0,0.8)] bg-gradient-to-br from-black to-[#C00000]/30">
                    <span class="font-bold text-white text-lg">{step.num}</span>
                  </div>
                </div>
                <div class="order-2 md:order-3 w-full md:w-5/12 pl-12 md:pl-24 text-left relative z-20">
                  <h3 class="text-3xl font-extrabold text-gray-900 mb-4 group-hover:text-a2ci-red transition-colors duration-300 font-heading">{step.title}</h3>
                  <p class="text-gray-600 text-lg leading-relaxed group-hover:text-gray-700 transition-colors duration-300">{step.desc}</p>
                </div>
              </>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

