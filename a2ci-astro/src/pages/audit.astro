---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import TimelineSteps from '../components/TimelineSteps.astro';
import Accordion from '../components/Accordion.astro';
---

<ServiceLayout
  title="Audit SSI - A2CI Prévention Incendie"
  description="Expertise en Audit de sécurité incendie par A2CI. Analyse réglementaire, audit de site et rapports détaillés en Gironde."
  heroTitle='Audit des Systèmes de <br><span class="text-[var(--a2ci-red)]">Sécurité Incendie.</span>'
  heroSubtitle="Dans le cadre de missions de Coordination SSI et de Bureau d'Études Techniques, nous assistons la maîtrise d'ouvrage dans ses audits d'installations SSI ainsi que les cabinets d'expertises en cas de dommages d'ouvrages."
  heroImage="/images/photo-audit-conseil.avif"
  breadcrumbs={[
    { label: "Accueil", href: "/" },
    { label: "Sécurité Incendie", href: "/#audit-conseil" },
    { label: "Audit des Systèmes de Sécurité Incendie" }
  ]}
  ctaTitle={"Besoin d'un <span class=\"text-a2ci-red\">audit SSI ?</span>"}
>

  <!-- Timeline -->
  <TimelineSteps
    title='Parcours de <span class="text-[var(--a2ci-red)]">Mise en Conformité.</span>'
    subtitle="Une méthodologie rigoureuse pour garantir la sécurité de votre établissement."
    steps={[
      { number: "01", title: "Analyse réglementaire", description: "Étude du contexte, des normes et du classement de l'établissement." },
      { number: "02", title: "Audit sur site", description: "Inspection complète du SSI et tests de fonctionnement." },
      { number: "03", title: "Contrôles techniques", description: "Vérification des installations, réseaux et équipements." },
      { number: "04", title: "Rapport d'audit", description: "Synthèse, écarts et préconisations de mise en conformité." }
    ]}
  />

  <!-- Section 1: Analyse du contexte -->
  <section class="bg-gray-50">
    <div class="container-custom">
      <div class="section-custom scroll-reveal">
        <div class="section-text">
          <div class="h2-bar">
            <span></span>
            <h2 class="section-title">Analyse du <span class="text-[var(--a2ci-red)]">contexte</span></h2>
          </div>
          <p class="mb-4 text-gray-600">
            Avant tout audit, une visite du site est réalisée et des réunions sont organisées avec l'ensemble des protagonistes afin de comprendre les différentes phases de travaux.
          </p>
          <p class="text-gray-600">
            L'Ingénieur Conseil prend en compte la réglementation en vigueur à l'époque des travaux et établit une trame d'étude avec les obligations liées au type et au classement de l'établissement.
          </p>
        </div>
        <div class="section-img">
          <div class="img-wrapper">
            <img src="/images/Analyse du contexte(audit&conseil).png" alt="Analyse du contexte" class="glow-border">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Audit sur site -->
  <section class="bg-gray-50">
    <div class="container-custom pt-0">
      <div class="section-custom reverse scroll-reveal">
        <div class="section-text">
          <div class="h2-bar">
            <span></span>
            <h2 class="section-title">Audit sur <span class="text-[var(--a2ci-red)]">site</span></h2>
          </div>
          <p class="mb-4 text-gray-600">
            L'Ingénieur Conseil visite l'ensemble de l'établissement afin de vérifier que les risques sont bien couverts par le SSI existant.
          </p>
          <p class="text-gray-600">
            Des essais sont réalisés, si possible en présence de l'entreprise de maintenance et du maître d'ouvrage pour une validation transparente et complète.
          </p>
        </div>
        <div class="section-img">
          <div class="img-wrapper">
            <img src="/images/Audit sur site(audit&conseil).png" alt="Audit sur site" class="glow-border">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Détail audit (Dark) -->
  <section id="detail-audit" class="section-dark">
    <div class="container-custom">
      <div class="scroll-reveal">
        <div class="text-center mb-16">
          <p class="text-[var(--a2ci-red)] font-bold uppercase tracking-widest text-xs mb-3">Expertise & Analyse</p>
          <h2 class="font-heading text-4xl font-bold text-white">Détail de <span class="text-red">l'Audit</span></h2>
        </div>

        <Accordion items={[
          {
            title: "Tests du système SSI",
            content: `<ul class="premium-list !text-gray-400">
              <li>Toutes les têtes de détection automatique d'incendie</li>
              <li>Tous les déclencheurs manuels et indicateurs d'action</li>
              <li>Tous les DAS, DAC, DCM</li>
              <li>Scénarios de mise en sécurité en manuel et en automatique</li>
            </ul>`
          },
          {
            title: "Contrôles visuels",
            content: `<p class="text-sm border-b border-white/10 pb-4 mb-4">Vérification du cheminement des réseaux SSI et DAS/DAC.</p>
            <ul class="premium-list !text-gray-400">
              <li><strong>Séparation des réseaux</strong> (NFC 15-100, NFS 61-932, NFS 61-970)</li>
              <li>Fixation des réseaux sur <strong>parties stables</strong> du bâtiment</li>
              <li>Absence de <strong>câbles volants</strong> et conformité des câbles</li>
              <li>Positionnement des <strong>équipements SSI</strong> (détecteurs, DM, DS)</li>
              <li><strong>Rebouchage</strong> des traversées coupe-feu</li>
            </ul>`
          },
          {
            title: "Rapport après audit",
            content: `<p class="text-sm">Rapport comprenant les essais réalisés, les observations sur le fonctionnement du SSI, le référentiel réglementaire et les solutions correctives pour mise en conformité ou remplacement du système.</p>`
          },
          {
            title: "Contenu du rapport d'audit",
            content: `<div class="space-y-4">
              <div>
                <p class="text-[9px] font-black uppercase tracking-widest text-[var(--a2ci-red)] mb-2">Analyse comparative</p>
                <ul class="premium-list !text-gray-400 !text-xs !space-y-1">
                  <li>Dossier de conception SSI initial</li>
                  <li>Rapports de (sous)commission de sécurité</li>
                  <li>Rapport du bureau de contrôle triennal</li>
                </ul>
              </div>
              <div>
                <p class="text-[9px] font-black uppercase tracking-widest text-[var(--a2ci-red)] mb-2">Axes d'amélioration</p>
                <p class="text-xs text-gray-400">Identification des écarts normatifs, propositions de modifications pour conformité et améliorations selon les normes actuelles (selon faisabilité technique).</p>
              </div>
            </div>`
          }
        ]} />
      </div>
    </div>
  </section>

</ServiceLayout>
