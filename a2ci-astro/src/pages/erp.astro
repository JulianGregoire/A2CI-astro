  listItems={[
    { title: "Classification & Conformité", description: "Analyse du type et de la catégorie de votre ERP, vérification des obligations réglementaires et mise en conformité complète." },
    { title: "Dossiers de Sécurité", description: "Constitution et suivi des dossiers pour les commissions de sécurité, permis de construire et autorisations de travaux." },
    { title: "Audit de Maintenance", description: "Contrôle des installations techniques, vérification des systèmes de sécurité incendie et planification de la maintenance préventive." }
  ]}
/>
