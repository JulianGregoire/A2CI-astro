---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroSection from '../components/HeroSection.astro';
import QualiopiBar from '../components/QualiopiBar.astro';
---
<BaseLayout title="Modalités d'inscription - A2CI Prévention">
  <Header />
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Formations", href: "/formations" },
    { label: "Modalités d'inscription" }
  ]} />

  <HeroSection
    title="Modalités"
    titleAccent="d'inscription."
    subtitle="Retrouvez ci-dessous les étapes clés et les modalités d'accès à nos sessions de formation professionnelle."
    backgroundImage="/images/catalogue_hero.png"
    ctaText="Découvrir les étapes"
    ctaLink="#steps"
  />

  <QualiopiBar />

  <!-- Steps Section -->
  <section id="steps" class="py-24 bg-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/3 h-full bg-gray-50/50 skew-x-12 translate-x-20 z-0"></div>

    <div class="max-w-[1150px] mx-auto px-8 relative z-10">
      <div class="mb-16 max-w-3xl">
        <div class="h2-bar">
          <span></span>
          <h2 class="section-title mb-6">Un processus d'inscription<br/><span class="text-[var(--a2ci-red)]">clair & structuré.</span></h2>
          <span></span>
        </div>
        <p class="text-gray-600 lg:text-lg font-light leading-relaxed">
          Nous avons simplifié nos démarches pour vous permettre de lancer vos formations dans les meilleures conditions et les plus brefs délais.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Étape 1 -->
        <div class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-gray-50 border border-gray-100 p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--a2ci-red)] hover:shadow-xl hover:bg-white">
          <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
            <span class="text-6xl font-black italic">01</span>
          </div>
          <div class="relative z-10">
            <h3 class="text-lg font-bold mb-4 uppercase tracking-tight text-gray-900 group-hover:text-[var(--a2ci-red)] transition-colors">Dossier Client</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-8">Identification de votre structure et enregistrement de votre fiche établissement pour faciliter vos demandes.</p>
          </div>
          <a href="/#contact" class="inline-flex items-center gap-2 text-[var(--a2ci-red)] font-bold text-xs uppercase tracking-widest hover:translate-x-1 transition-transform">
            Compléter ici
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
        </div>

        <!-- Étape 2 -->
        <div class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-gray-50 border border-gray-100 p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--a2ci-red)] hover:shadow-xl hover:bg-white" style="transition-delay: 100ms;">
          <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
            <span class="text-6xl font-black italic">02</span>
          </div>
          <div class="relative z-10">
            <h3 class="text-lg font-bold mb-4 uppercase tracking-tight text-gray-900 group-hover:text-[var(--a2ci-red)] transition-colors">Étude & Devis</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-8">Analyse de vos besoins et transmission d'un devis détaillé sous un délai moyen de quelques heures.</p>
          </div>
        </div>

        <!-- Étape 3 -->
        <div class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-gray-50 border border-gray-100 p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--a2ci-red)] hover:shadow-xl hover:bg-white" style="transition-delay: 200ms;">
          <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
            <span class="text-6xl font-black italic">03</span>
          </div>
          <div class="relative z-10">
            <h3 class="text-lg font-bold mb-4 uppercase tracking-tight text-gray-900 group-hover:text-[var(--a2ci-red)] transition-colors">Pré-inscription</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-6">Validation des dates et horaires. Réception du devis signé avec bon pour accord.</p>
          </div>
        </div>

        <!-- Étape 4 -->
        <div class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-gray-50 border border-gray-100 p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--a2ci-red)] hover:shadow-xl hover:bg-white" style="transition-delay: 300ms;">
          <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
            <span class="text-6xl font-black italic">04</span>
          </div>
          <div class="relative z-10">
            <h3 class="text-lg font-bold mb-4 uppercase tracking-tight text-gray-900 group-hover:text-[var(--a2ci-red)] transition-colors">Validation Finale</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-8">Retour de la Convention de Formation signée pour sécuriser définitivement votre session.</p>
          </div>
        </div>
      </div>

      <!-- Délais et Engagement -->
      <div class="mt-24 bg-gray-900 rounded-3xl p-10 lg:p-16 border border-white/5 relative overflow-hidden flex flex-col md:flex-row gap-12 items-center">
        <div class="absolute inset-0 z-0 opacity-20">
          <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-[var(--a2ci-red)]/20 to-transparent"></div>
        </div>

        <div class="relative z-10 md:w-1/3">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-[var(--a2ci-red)] rounded-2xl mb-8 shadow-lg shadow-[var(--a2ci-red)]/20">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h4 class="text-2xl font-extrabold text-white uppercase mb-4 tracking-tight">Délais de traitement</h4>
          <p class="text-gray-400 text-sm font-medium leading-relaxed">Réactivité immédiate et planification stratégique pour vos formations.</p>
        </div>

        <div class="relative z-10 md:w-2/3 space-y-8">
          <div class="p-8 bg-white/5 rounded-2xl border border-white/10 backdrop-blur-sm">
            <p class="text-xl md:text-2xl text-white font-bold leading-tight">
              Inscriptions traitées sous un délai allant de <span class="text-[var(--a2ci-red)]">quelques heures à 6 mois</span>.
            </p>
          </div>
          <p class="text-gray-400 italic font-light text-lg">
            "Nous nous adaptons en permanence à vos disponibilités et aux contraintes opérationnelles de votre secteur."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-16 bg-white">
    <div class="max-w-[1150px] mx-auto px-8 text-center">
      <h2 class="section-title mb-8">Prêt à planifier votre <span class="text-[var(--a2ci-red)]">session ?</span></h2>
      <p class="text-gray-500 mb-10 font-light">Prenez contact avec notre responsable pédagogique pour une étude personnalisée de votre plan de formation.</p>
      <div class="flex flex-wrap justify-center gap-6">
        <a href="/#contact" class="px-10 py-5 bg-[var(--a2ci-red)] text-white rounded-full text-sm font-bold uppercase tracking-widest hover:bg-[#C00000] transition-all shadow-xl">Nous contacter</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
