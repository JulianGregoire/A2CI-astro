---
import FormationLayout from '../layouts/FormationLayout.astro';
---

<FormationLayout
  title="Sauveteur Secouriste du Travail (SST) - A2CI Prévention"
  description="Formation Sauveteur Secouriste du Travail (SST). Maîtrisez les gestes d'urgence et la prévention des risques professionnels avec A2CI."
  heroTitle='Sauveteur Secouriste<br /><span class="text-[var(--a2ci-red)]">du Travail (SST).</span>'
  heroSubtitle="Devenez le premier maillon de la chaîne de secours et un acteur majeur de la prévention des risques professionnels dans votre entreprise."
  heroImage="/images/Secourisme : SST.png"
  parentCategory="secourisme"
  breadcrumbLabel="Sauveteur Secouriste du Travail (SST)"
  objectivesIntro="La formation SST permet d'acquérir les compétences nécessaires pour intervenir face à un accident et participer à la prévention des risques professionnels."
  block1Title='Protéger & <span class="text-[var(--a2ci-red)]">Examiner.</span>'
  block1Items={[
    "Examiner la victime pour déterminer les actions à entreprendre.",
    "Alerter, faire alerter et informer les secours spécialisés de manière efficace.",
    "Secourir la victime en réalisant les gestes appropriés."
  ]}
  block1Image="/images/Secourisme : SST.png"
  block2Title='Secourir & <span class="text-[var(--a2ci-red)]">Prévenir.</span>'
  block2Items={[
    "Réagir face à une victime consciente (saignements, étouffement, malaise, brûlures, traumatismes).",
    "Réagir face à une victime inconsciente qui ne respire pas (RCP + DAE).",
    "Réagir face à une victime inconsciente qui respire (PLS, contrôle du comportement)."
  ]}
  block2Image="/images/secourisme.png"
  reglementationIntro="La formation SST est encadrée par l'INRS et répond aux obligations du Code du Travail concernant la présence de secouristes sur le lieu de travail."
  reglementationCards={[
    { number: "01", title: "Certification <br>INRS", description: "Délivrance du certificat de Sauveteur Secouriste du Travail valable 24 mois sur tout le territoire national." },
    { number: "02", title: "Code du <br>Travail", description: "Réponse aux articles R4224-15 et R4224-16 du Code du Travail imposant une organisation des secours." },
    { number: "03", title: "Prévention <br>Active", description: "Le SST contribue à la mise en œuvre d'actions de prévention et à la remontée d'informations." }
  ]}
  moyensIntro="Utilisation de matériel pédagogique conforme aux exigences de l'INRS pour une formation pratique et réaliste."
  moyensItems={[
    '<strong class="text-gray-900 font-bold uppercase tracking-widest text-xs">Simulations</strong> : Mannequins (adulte, enfant, nourrisson) & Valise INRS.',
    '<strong class="text-gray-900 font-bold uppercase tracking-widest text-xs">Innovation</strong> : Défibrillateurs de formation (automatique ou semi-automatique).',
    '<strong class="text-gray-900 font-bold uppercase tracking-widest text-xs">Pédagogie</strong> : Matériel de mise en scène, vidéo projecteur et écran sur pied.',
    `<strong class="text-gray-900 font-bold uppercase tracking-widest text-xs">Documentation</strong> : Remise du mémento SST de l'INRS.`
  ]}
  moyensImage="/images/catalogue_secourisme.png"
  quote='Apprendre à protéger, examiner et secourir pour <span class="text-[var(--a2ci-red)] font-normal">sauver des vies</span> tout en agissant sur la prévention des risques professionnels.'
  stats={[
    { value: "14h", label: "Durée Initiale" },
    { value: "10", label: "Pers. Max / Session" },
    { value: "100%", label: "Opérationnel" },
    { value: "INRS", label: "Référentiel National" }
  ]}
  ctaTitle='Besoin de former vos <span class="text-[var(--a2ci-red)]">collaborateurs ?</span>'
  pdfUrl="https://www.a2ci-prevention-incendie.fr/IMG/pdf/fp-sst.pdf"
/>
