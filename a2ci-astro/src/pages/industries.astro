---
import SectorLayout from '../layouts/SectorLayout.astro';
---

<SectorLayout
  title="Industries - A2CI Prévention Incendie"
  description="Sécurité incendie des sites industriels - ICPE, stockage, production par A2CI."
  heroTitle="Sécurité des Sites <span class='text-[var(--a2ci-red)]'>Industriels</span>."
  heroSubtitle="Expertise en prévention incendie pour les sites industriels, installations classées et zones de stockage."
  heroImage="/images/ssi_hero.png"
  breadcrumbLabel="Industries"
  sectionTitle="Maîtrise des risques <span class='text-[var(--a2ci-red)]'>industriels</span>."
  sectionIntro="Les sites industriels présentent des risques incendie spécifiques liés aux procédés, aux produits stockés et aux installations techniques. Notre expertise couvre l'ensemble de ces problématiques."
  sectionImage="/images/sector_industries.png"
  listItems={[
    { title: "Analyse Risques Spécifiques", description: "Identification et évaluation des risques propres à votre activité industrielle : procédés, stockage, manipulation de produits dangereux." },
    { title: "Systèmes Extinction Automatique", description: "Dimensionnement et suivi des systèmes d'extinction automatique : sprinkleurs, brouillard d'eau, mousse, gaz inerte." },
    { title: "Conformité ICPE", description: "Mise en conformité avec la réglementation des Installations Classées pour la Protection de l'Environnement." }
  ]}
/>
