---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroSection from '../components/HeroSection.astro';

const articles = [
  {
    slug: "20-ans-a2ci",
    category: "Vie de l'agence",
    date: "24 Mars 2026",
    readTime: "2 min de lecture",
    title: "Événement : Les 20 ans d'A2CI.",
    excerpt: "En juin 2026, fêtons ensemble les 20 ans de l'entreprise à l'hippodrome de Langon. Un moment historique pour A2CI.",
    image: "/images/a2ci_20_years_anniversary.png",
    filterCat: "Vie de l'agence",
  },
  {
    slug: "medaille-bronze-2025",
    category: "Distinction",
    date: "02 Juillet 2025",
    readTime: "2 min de lecture",
    title: "Médaille Bronze - Label Fournisseur Provigis.",
    excerpt: "Nous sommes heureux de vous annoncer que la plateforme \"Provigis\" nous a attribué à nouveau la médaille \"Tiers Responsable de Bronze\" pour l'année 2025.",
    image: "/images/c5e842f87a518a33-ae77c.jpg",
    filterCat: "Distinction",
  },
  {
    slug: "medaille-bronze-2023",
    category: "Distinction",
    date: "24 Juillet 2023",
    readTime: "2 min de lecture",
    title: "Médaille Bronze - Label Fournisseur Provigis.",
    excerpt: "La plateforme \"Provigis\" vient d'attribuer à A2Ci. Prévention Incendie, la Médaille Tiers Responsable de Bronze.",
    image: "/images/e9f0fcdae55f9430-b801c.jpg",
    filterCat: "Distinction",
  },
  {
    slug: "evenement-repris-2021",
    category: "Vie de l'agence",
    date: "16 Février 2021",
    readTime: "3 min de lecture",
    title: "Évènement : L'équipe reprend le flambeau.",
    excerpt: "Suite au départ à la retraite de son fondateur Monsieur Rémy DENIS, l'équipe d'A2Ci Prévention incendie poursuit l'aventure.",
    image: "https://images.pexels.com/photos/3184418/pexels-photo-3184418.jpeg",
    filterCat: "Vie de l'agence",
  },
  {
    slug: "information-covid-19",
    category: "Information",
    date: "15 Mai 2020",
    readTime: "4 min de lecture",
    title: "Information Covid-19 & Continuité.",
    excerpt: "Point sur la poursuite de l'activité, le respect des gestes barrières et l'organisation des rendez-vous durant la crise sanitaire.",
    image: "/images/b278f7cfa2a384f8-1a792.jpg",
    filterCat: "Information",
  },
  {
    slug: "label-provigis-2020",
    category: "Conformité",
    date: "17 Mars 2020",
    readTime: "2 min de lecture",
    title: "Label Fournisseur Provigis.",
    excerpt: "A2Ci. Prévention Incendie porte désormais le label \"Fournisseur Provigis\" prouvant la conformité de son dossier légal.",
    image: "/images/688222314548f953-da4e3.png",
    filterCat: "Conformité",
  },
  {
    slug: "referencement-formation",
    category: "Formation",
    date: "27 Décembre 2016",
    readTime: "5 min de lecture",
    title: "Référencement des organismes de formation.",
    excerpt: "Focus sur la capacité du prestataire de formation à dispenser une formation de qualité et l'obtention de la certification QUALICERT.",
    image: "/images/referencement_blog.png",
    filterCat: "Formation",
  },
  {
    slug: "securite-management-service",
    category: "Expertise",
    date: "24 Juin 2015",
    readTime: "6 min de lecture",
    title: "Sécurité Management service.",
    excerpt: "Découvrez notre démarche expertise pour l'analyse et l'accroissement global de la sécurité dans vos établissements.",
    image: "/images/securite_management_blog.png",
    filterCat: "Expertise",
  },
  {
    slug: "inauguration-2013",
    category: "Vie de l'agence",
    date: "06 Septembre 2013",
    readTime: "3 min de lecture",
    title: "Inauguration des nouveaux locaux à Mazères.",
    excerpt: "Présentation, sensibilisation et échanges sur la sécurité incendie des ERP et ERT lors de l'inauguration de nos bureaux.",
    image: "/images/A2CCI.jpg",
    filterCat: "Vie de l'agence",
  },
];
---
<BaseLayout title="Blog & Actualités - A2CI Prévention">
  <Header />
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Le Blog A2CI" }
  ]} />

  <HeroSection
    title='Le Blog<br /><span class="text-[var(--a2ci-red)]">A2CI.</span>'
    subtitle="Décryptages, conseils de prévention et veille réglementaire pour votre sécurité-incendie et santé au travail."
    backgroundImage="https://images.pexels.com/photos/3184419/pexels-photo-3184419.jpeg"
    ctaText="Lire les articles"
    ctaHref="#feed"
    centered
  />

  <section id="feed" class="py-24">
    <div class="max-w-[1150px] mx-auto px-8">

      <!-- Filtres -->
      <div class="flex flex-wrap items-center gap-4 mb-16" id="blog-filters">
        <button data-filter="all" class="filter-btn active px-6 py-2.5 bg-black text-white rounded-full text-xs font-bold uppercase tracking-widest transition-all">Tous les articles</button>
        <button data-filter="Distinction" class="filter-btn px-6 py-2.5 bg-white text-gray-500 rounded-full text-xs font-bold uppercase tracking-widest border border-gray-100 hover:border-[#C00000]/30 hover:text-[#C00000] transition-all">Distinctions</button>
        <button data-filter="Vie de l'agence" class="filter-btn px-6 py-2.5 bg-white text-gray-500 rounded-full text-xs font-bold uppercase tracking-widest border border-gray-100 hover:border-[#C00000]/30 hover:text-[#C00000] transition-all">Vie de l'agence</button>
        <button data-filter="Formation" class="filter-btn px-6 py-2.5 bg-white text-gray-500 rounded-full text-xs font-bold uppercase tracking-widest border border-gray-100 hover:border-[#C00000]/30 hover:text-[#C00000] transition-all">Formation</button>
        <button data-filter="Expertise" class="filter-btn px-6 py-2.5 bg-white text-gray-500 rounded-full text-xs font-bold uppercase tracking-widest border border-gray-100 hover:border-[#C00000]/30 hover:text-[#C00000] transition-all">Expertise</button>
      </div>

      <!-- Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10" id="blog-grid">
        {articles.map((article, i) => (
          <article
            class="blog-card scroll-reveal relative group cursor-pointer"
            data-category={article.filterCat}
            style={i > 0 ? `transition-delay: ${(i % 3) * 100}ms;` : ''}
          >
            <a href={`/blog/${article.slug}`} class="absolute inset-0 z-20"></a>
            <div class="blog-image">
              <span class="category-badge">{article.category}</span>
              <img src={article.image} alt={article.title} />
            </div>
            <div class="p-8">
              <div class="flex items-center gap-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">
                <span>{article.date}</span>
                <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
                <span>{article.readTime}</span>
              </div>
              <h3 class="text-xl font-bold mb-4 leading-tight group-hover:text-[var(--a2ci-red)] transition-colors">{article.title}</h3>
              <p class="text-gray-600 text-sm font-light leading-relaxed mb-6 line-clamp-3">{article.excerpt}</p>
              <div class="inline-flex items-center gap-2 text-[var(--a2ci-red)] font-bold text-xs uppercase tracking-widest hover:gap-3 transition-all relative z-10">
                Lire l'article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-24 bg-black overflow-hidden relative">
    <div class="absolute top-0 right-0 w-1/3 h-full bg-[var(--a2ci-red)]/10 skew-x-12 translate-x-1/2"></div>
    <div class="relative z-10 max-w-[1150px] mx-auto px-8">
      <div class="max-w-3xl">
        <h2 class="font-heading text-4xl font-bold text-white mb-6 uppercase tracking-tight">Restez informé de la <span class="text-[var(--a2ci-red)]">veille règlementaire.</span></h2>
        <p class="text-gray-400 mb-10 text-lg font-light">Inscrivez-vous à notre newsletter mensuelle pour recevoir l'essentiel de l'actualité sécurité directement dans votre boîte mail.</p>
        <form class="flex flex-col sm:flex-row gap-4">
          <input type="email" placeholder="Votre adresse email" class="flex-grow px-8 py-5 bg-white/5 border border-white/10 rounded-2xl text-white focus:outline-none focus:border-[#C00000] transition-all font-light" />
          <button type="submit" class="px-10 py-5 bg-[var(--a2ci-red)] text-white font-bold rounded-2xl hover:bg-[#C00000] transition-all uppercase tracking-widest text-xs">S'abonner</button>
        </form>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .blog-card {
    background: white;
    border-radius: 2rem;
    overflow: hidden;
    border: 1px solid #f1f1f1;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .blog-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.06);
    border-color: var(--a2ci-red);
  }
  .blog-image {
    height: 240px;
    overflow: hidden;
    position: relative;
  }
  .blog-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .blog-card:hover .blog-image img {
    transform: scale(1.05);
  }
  .category-badge {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    background: var(--a2ci-red);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    box-shadow: 0 5px 15px rgba(227, 6, 19, 0.2);
  }
</style>

<script>
  const filterButtons = document.querySelectorAll('.filter-btn');
  const blogArticles = document.querySelectorAll('.blog-card');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      filterButtons.forEach(b => {
        b.classList.remove('bg-black', 'text-white');
        b.classList.add('bg-white', 'text-gray-500');
      });
      btn.classList.remove('bg-white', 'text-gray-500');
      btn.classList.add('bg-black', 'text-white');

      const filterValue = btn.getAttribute('data-filter');

      blogArticles.forEach(article => {
        const category = article.getAttribute('data-category');
        article.style.opacity = '0';
        article.style.transform = 'translateY(20px)';

        setTimeout(() => {
          if (filterValue === 'all' || category === filterValue) {
            (article as HTMLElement).style.display = 'block';
            setTimeout(() => {
              article.style.opacity = '1';
              article.style.transform = 'translateY(0)';
            }, 50);
          } else {
            (article as HTMLElement).style.display = 'none';
          }
        }, 300);
      });
    });
  });
</script>
