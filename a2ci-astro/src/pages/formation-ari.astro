---
import FormationLayout from '../layouts/FormationLayout.astro';
---
<FormationLayout
  title="ARI - Appareil Respiratoire Isolant - A2CI Prévention"
  description="Formation Appareil Respiratoire Isolant (ARI). Apprenez à utiliser l'ARI en binôme, maîtrisez les contraintes et la sécurité avec A2CI."
  heroTitle='Appareil Respiratoire<br /><span class="text-[var(--a2ci-red)]">Isolant (ARI).</span>'
  heroSubtitle="Maîtrisez l'usage de l'ARI pour intervenir en milieu hostile et protéger votre intégrité physique lors des opérations de secours."
  heroImage="/images/ari_formation.png"
  parentCategory="incendie"
  breadcrumbLabel="Appareil Respiratoire Isolant (ARI)"
  objectivesIntro="Une formation intensive pour appréhender les contraintes de l'ARI et devenir opérationnel en binôme dans des conditions de visibilité réduite."
  block1Title='Comprendre & <span class="text-[var(--a2ci-red)]">Maîtriser.</span>'
  block1Items={["Informer sur les contraintes physiologiques liées au port de l'ARI.","Connaître les principes d'utilisation et maîtriser le matériel.","Maîtriser les procédures de mise en œuvre et de contrôle."]}
  block1Image="/images/ari_formation.png"
  block2Title='Progresser & <span class="text-[var(--a2ci-red)]">Intervenir.</span>'
  block2Items={["Apprendre à manipuler l'ARI en binôme en toute sécurité.","Progresser dans des environnements enfumés ou hostiles.","Remise d'un mémento pratique personnalisé à chaque participant."]}
  block2Image="/images/ari_recyclage.png"
  reglementationIntro="Le port de l'ARI impose une parfaite connaissance de soi et du matériel pour une intervention sécurisée."
  reglementationCards={[
    { number: "01", title: "Contraintes <br>physiques", description: "Gestion de l'effort, de la respiration et de l'hydratation sous l'équipement." },
    { number: "02", title: "Calcul <br>d'autonomie", description: "Maîtrise de la règle de consommation d'air et planification du retrait." },
    { number: "03", title: "Missions <br>en binôme", description: "Communication, entraide et cohésion pour une sécurité mutuelle garantie." }
  ]}
  moyensIntro="Nous utilisons le matériel réel de votre établissement ou nos propres équipements certifiés."
  moyensItems={[
    '<strong class="text-gray-900 font-bold uppercase tracking-widest text-xs">Matériel</strong> : ARI (charge établissement), masques & bouteilles.',
    '<strong class="text-gray-900 font-bold uppercase tracking-widest text-xs">Immersion</strong> : Générateur de fumée & bac à feu « écologique ».',
    '<strong class="text-gray-900 font-bold uppercase tracking-widest text-xs">Support</strong> : PC portable & supports pédagogiques interactifs.'
  ]}
  moyensImage="/images/ari_formation.png"
  quote={"Maîtriser l'ARI en binôme pour <span class=\"text-[var(--a2ci-red)] font-normal\">intervenir en milieu hostile</span> avec confiance et sécurité."}
  stats={[
    { value: "15+", label: "Programmes" },
    { value: "10", label: "Pers. Max / Session" },
    { value: "100%", label: "Opérationnel" },
    { value: "Mémento", label: "Offert à chacun" }
  ]}
  ctaTitle={"Prêt pour l'intervention en <span class=\"text-[var(--a2ci-red)]\">milieu hostile ?</span>"}
  pdfUrl="https://www.a2ci-prevention-incendie.fr/IMG/pdf/fp-ari.pdf"
/>
