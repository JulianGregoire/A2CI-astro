---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroSection from '../components/HeroSection.astro';
import QualiopiBar from '../components/QualiopiBar.astro';
import FormationCard from '../components/FormationCard.astro';

const formations = [
  {
    href: "/formation-sst", id: "sst", category: "sst", badgeColor: "bg-[var(--a2ci-red)]", badge: "Certification INRS",
    image: "/images/Secourisme : SST.png",
    title: 'Sauveteur Secouriste <br><span class="text-[var(--a2ci-red)]">du Travail (SST)</span>',
    description: "Formation certifiante pour intervenir efficacement face aux accidents du travail et maîtriser les gestes de secours d'urgence.",
    duration: "2 JOURS (14H)"
  },
  {
    href: "/formation-dae", id: "dae", category: "urgence", badgeColor: "bg-black", badge: "Urgence Vitale",
    image: "/images/dae_formation.png",
    title: 'Initiation au <br><span class="text-[var(--a2ci-red)]">Défibrillateur (DAE)</span>',
    description: "Apprenez à reconnaître l'arrêt cardiaque et à utiliser un DAE pour augmenter considérablement les chances de survie.",
    duration: "1/2 JOURNÉE"
  },
  {
    href: "/formation-mac-sst", id: "mac-sst", category: "sst", badgeColor: "bg-[var(--a2ci-red)]", badge: "Maintien Acquis",
    image: "/images/mac_sst_formation.png",
    title: 'Maintien Compétences <br><span class="text-[var(--a2ci-red)]">MAC SST</span>',
    description: "Actualisez vos connaissances de sauveteur secouriste et prolongez la validité de votre certificat INRS.",
    duration: "1 JOURNÉE"
  },
  {
    href: "/formation-ps", id: "ps", category: "sensibilisation", badgeColor: "bg-gray-500", badge: "Sensibilisation",
    image: "/images/premiers_secours_formation.png",
    title: 'Gestes de <br><span class="text-[var(--a2ci-red)]">Premiers Secours</span>',
    description: "Une initiation complète aux gestes qui sauvent pour agir sereinement en attendant l'arrivée des secours.",
    duration: "SUR-MESURE"
  }
];

const filters = [
  { value: "all", label: "Tout le catalogue" },
  { value: "sst", label: "SST (Initial & MAC)" },
  { value: "urgence", label: "Urgence DAE" },
  { value: "sensibilisation", label: "Sensibilisation" }
];
---

<BaseLayout title="Formations SECOURISME - A2CI Prévention" description="Formations Secourisme et Santé au Travail (SST), Initiation DAE par A2CI. Les gestes qui sauvent en milieu professionnel." bodyClass="bg-gray-50 overflow-x-hidden w-full">
  <Header />
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Formations", href: "/formations" },
    { label: "Formations SECOURISME" }
  ]} />

  <HeroSection
    title='Formations<br /><span class="text-[var(--a2ci-red)]">SECOURISME.</span>'
    subtitle="Maîtrisez les gestes d'urgence et la conduite à tenir pour porter secours en toutes circonstances."
    backgroundImage="/images/secourisme.png"
    ctaText="Voir le catalogue"
    ctaHref="/formations"
    centered
  />

  <QualiopiBar />

  <section class="py-24 bg-gray-50">
    <div class="container-custom">
      <!-- Filtres -->
      <div class="flex flex-wrap items-center justify-center gap-4 mb-20 scroll-reveal">
        {filters.map((f, i) => (
          <button data-filter={f.value} class={`filter-btn px-6 py-2.5 rounded-full text-[10px] font-bold uppercase tracking-widest border border-gray-100 transition-all ${i === 0 ? 'active' : 'bg-white text-gray-500'}`}>
            {f.label}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {formations.map((f) => (
          <FormationCard {...f} />
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-[1150px] mx-auto px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-12 text-center">
        <div class="scroll-reveal">
          <div class="text-4xl font-bold text-[var(--a2ci-red)] mb-2">15+</div>
          <div class="text-xs font-bold text-gray-400 uppercase tracking-widest">Programmes</div>
        </div>
        <div class="scroll-reveal" style="transition-delay: 100ms;">
          <div class="text-4xl font-bold text-[var(--a2ci-red)] mb-2">10</div>
          <div class="text-xs font-bold text-gray-400 uppercase tracking-widest">Pers. Max / Session</div>
        </div>
        <div class="scroll-reveal" style="transition-delay: 200ms;">
          <div class="text-4xl font-bold text-[var(--a2ci-red)] mb-2">100%</div>
          <div class="text-xs font-bold text-gray-400 uppercase tracking-widest">Opérationnel</div>
        </div>
        <div class="scroll-reveal" style="transition-delay: 300ms;">
          <div class="text-4xl font-bold text-[var(--a2ci-red)] mb-2">Sur-mesure</div>
          <div class="text-xs font-bold text-gray-400 uppercase tracking-widest">Adaptation locale</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-black text-white text-center border-t border-white/5">
    <div class="max-w-4xl mx-auto px-8 relative z-10">
      <h2 class="font-heading text-4xl font-bold mb-8 uppercase italic">Formations sur site ou en centre</h2>
      <p class="text-xl text-gray-400 mb-12 font-light">Nous intervenons directement dans votre établissement ou vous accueillons en centre selon votre programmation.</p>
      <a href="/#contact" class="inline-block px-10 py-5 bg-[var(--a2ci-red)] rounded-full text-sm font-bold uppercase tracking-widest hover:bg-[#C00000] transition-all shadow-xl shadow-[var(--a2ci-red)]/40">Demander une session</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .formation-card {
    background: white;
    border-radius: 2.5rem;
    border: 1px solid #f1f1f1;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }
  .formation-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.05);
    border-color: var(--a2ci-red);
  }
  .filter-btn.active {
    background: black;
    color: white;
    border-color: black;
  }
</style>

<script>
  const filterButtons = document.querySelectorAll('.filter-btn');
  const formationCards = document.querySelectorAll('.formation-card');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      filterButtons.forEach(b => {
        b.classList.remove('active');
        b.classList.add('bg-white', 'text-gray-500');
      });
      btn.classList.remove('bg-white', 'text-gray-500');
      btn.classList.add('active');

      const filterValue = btn.getAttribute('data-filter');

      formationCards.forEach(card => {
        const category = card.getAttribute('data-category');
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';

        setTimeout(() => {
          if (filterValue === 'all' || category === filterValue) {
            card.style.display = 'block';
            setTimeout(() => {
              card.style.opacity = '1';
              card.style.transform = 'translateY(0)';
            }, 50);
          } else {
            card.style.display = 'none';
          }
        }, 300);
      });
    });
  });
</script>
