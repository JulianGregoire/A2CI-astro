---
/**
 * Qualiopi certification bar - shared between formation pages
 */
---

<section class="py-12 bg-white border-b border-gray-100">
  <div class="max-w-[1440px] mx-auto px-8">
    <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-16 text-center md:text-left">
      <div class="flex items-center gap-5 group">
        <div class="p-3 bg-gray-50 rounded-2xl group-hover:bg-white group-hover:shadow-xl transition-all duration-500 border border-gray-100">
          <img src="/images/qualiopi.png" alt="Qualiopi" class="h-14 w-auto object-contain" />
        </div>
        <div class="flex flex-col">
          <div class="text-sm font-bold text-gray-900 uppercase tracking-widest leading-tight mb-1">Certifié Qualiopi</div>
          <div class="text-[10px] text-gray-500 uppercase leading-relaxed max-w-[400px]">
            La certification qualité a été délivrée au titre de la catégorie d'action suivante : <span class="text-gray-900 font-bold">actions de formation</span>
          </div>
        </div>
      </div>
      <div class="hidden md:block h-12 w-px bg-gray-200"></div>
      <div class="flex items-center gap-6">
        <div class="text-center">
          <div class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-2">Organisme de formation</div>
          <div class="font-heading text-xl font-black text-gray-900 tracking-tighter uppercase">Data Docké</div>
        </div>
      </div>
    </div>
  </div>
</section>
