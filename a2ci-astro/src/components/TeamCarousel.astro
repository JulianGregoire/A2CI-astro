---
const teamMembers = [
  { name: "Jérôme TEXIER", role: "Président", image: "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=800&auto=format&fit=crop", offset: false },
  { name: "Géraldine BUY", role: "Associée & RH", image: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=800&auto=format&fit=crop", offset: true },
  { name: "Magalie CZESKI", role: "Responsable BE", image: "https://images.unsplash.com/photo-1580489944761-15a19d654956?q=80&w=800&auto=format&fit=crop", offset: false },
  { name: "David ZERBIB", role: "Responsable Activité", image: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=800&auto=format&fit=crop", offset: true },
  { name: "William MASSIAS", role: "Coordination SSI", image: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?q=80&w=800&auto=format&fit=crop", offset: false },
  { name: "Emmanuel LAMBERT", role: "Formation & Conseil", image: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=800&auto=format&fit=crop", offset: true },
  { name: "Thibault CHAUSSIER", role: "Technicien BE", image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=800&auto=format&fit=crop", offset: false },
  { name: "Angélique ETCHEBERIGARAY", role: "Technicienne BE", image: "https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=800&auto=format&fit=crop", offset: true },
  { name: "Caroline MOREAU", role: "Technicienne BE", image: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=800&auto=format&fit=crop", offset: false },
];
---

<section id="equipe" class="bg-gray-50 py-16 lg:py-24 overflow-hidden relative">
  <div class="container-custom py-0 mb-12">
    <div class="max-w-3xl text-left">
      <div class="h2-bar">
        <span></span>
        <h2 class="section-title mb-6">Ils forment notre <span class="text-a2ci-red">collectif</span></h2>
      </div>
      <p class="text-sm text-gray-600 sm:text-base leading-relaxed">L'alliance de l'ingénierie et de l'expérience opérationnelle.</p>
    </div>
  </div>

  <div class="container-custom py-0">
    <div class="relative w-full group">
      <button id="team-left" class="absolute left-2 lg:left-4 top-1/2 -translate-y-1/2 z-30 flex h-10 w-10 lg:h-14 lg:w-14 items-center justify-center rounded-full bg-white/90 backdrop-blur-sm border border-gray-100 text-gray-800 hover:text-a2ci-red shadow-lg transition-opacity opacity-70 hover:opacity-100">
        <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>

      <button id="team-right" class="absolute right-2 lg:right-4 top-1/2 -translate-y-1/2 z-30 flex h-10 w-10 lg:h-14 lg:w-14 items-center justify-center rounded-full bg-white/90 backdrop-blur-sm border border-gray-100 text-gray-800 hover:text-a2ci-red shadow-lg transition-opacity opacity-70 hover:opacity-100">
        <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>

      <div id="team-scroll-container" class="flex overflow-x-auto gap-6 sm:gap-8 px-4 sm:px-12 pb-16 pt-8 scrollbar-hide scroll-smooth items-center snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch;">
        {teamMembers.map((member) => (
          <div class:list={["min-w-[260px] sm:min-w-[300px] flex flex-col group snap-center", member.offset ? "mt-8 lg:mt-16" : ""]}>
            <div class="relative aspect-[3/4] w-full overflow-hidden rounded-2xl shadow-lg transition-transform duration-500 group-hover:scale-[1.02]">
              <img src={member.image} alt={member.name} class="h-full w-full object-cover pointer-events-none filter grayscale group-hover:grayscale-0 transition-all duration-700" />
            </div>
            <div class="mt-5 text-center">
              <h3 class="text-xl font-extrabold text-gray-900 font-heading tracking-tight">{member.name}</h3>
              <p class="text-xs font-bold text-a2ci-red uppercase tracking-widest mt-1">{member.role}</p>
            </div>
          </div>
        ))}
        <div class="min-w-[20px] snap-center"></div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('team-left')?.addEventListener('click', () => {
    const container = document.getElementById('team-scroll-container');
    const scrollAmount = window.innerWidth < 768 ? 280 : 340;
    container?.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });
  document.getElementById('team-right')?.addEventListener('click', () => {
    const container = document.getElementById('team-scroll-container');
    const scrollAmount = window.innerWidth < 768 ? 280 : 340;
    container?.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });
</script>
