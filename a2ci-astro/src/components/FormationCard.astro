---
interface Props {
  href: string;
  image: string;
  badge: string;
  badgeColor?: string;
  title: string;
  description: string;
  duration: string;
  category: string;
  id?: string;
}

const { href, image, badge, badgeColor = 'bg-gray-500', title, description, duration, category, id } = Astro.props;
---

<a href={href} id={id} class="formation-card scroll-reveal !p-0 flex flex-col h-full" data-category={category}>
  <div class="relative h-64 overflow-hidden">
    <img src={image} alt={title.replace(/<[^>]*>/g, '')} class="w-full h-full object-cover transition-transform duration-700 hover:scale-110" />
    <div class="absolute top-6 left-6">
      <span class={`px-4 py-1.5 ${badgeColor} text-white text-[10px] font-bold uppercase tracking-widest rounded-full shadow-lg`}>{badge}</span>
    </div>
  </div>
  <div class="p-10 flex flex-col flex-grow">
    <div class="mb-6">
      <h3 class="text-2xl font-bold uppercase tracking-tight leading-tight" set:html={title} />
    </div>
    <p class="text-gray-500 text-sm font-light leading-relaxed mb-8 line-clamp-3">{description}</p>
    <div class="mt-auto">
      <div class="flex items-center gap-3 mb-8 text-gray-400">
        <svg class="w-4 h-4 text-[var(--a2ci-red)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 2m6-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span class="text-[10px] font-bold uppercase tracking-[0.2em]">Durée : {duration}</span>
      </div>
      <span class="block w-full py-4 bg-gray-100 text-gray-900 text-center rounded-xl hover:bg-gray-200 transition-all text-[10px] font-bold uppercase tracking-widest border border-gray-200">En savoir plus</span>
    </div>
  </div>
</a>
