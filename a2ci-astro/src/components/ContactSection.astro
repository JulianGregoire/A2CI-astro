---
---
<section id="contact" class="relative w-full bg-[#0a0a0a] py-24 overflow-hidden text-white border-t border-white/5">
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0 opacity-30" style="background-image: linear-gradient(#333 1px, transparent 1px), linear-gradient(90deg, #333 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle,_transparent_30%,_#0a0a0a_85%)]"></div>
    <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-[#0a0a0a] to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0a0a0a] to-transparent"></div>
  </div>

  <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/4 w-[600px] h-[600px] bg-a2ci-red opacity-10 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 px-4 lg:grid-cols-[1.1fr,0.9fr]">
    <div>
      <h2 class="font-heading text-3xl sm:text-4xl mb-6 font-bold text-white">Parler de la sécurité incendie de votre établissement.</h2>
      <p class="mb-8 max-w-xl text-gray-400 leading-relaxed">Projet de construction, mise en conformité, audit ou formation&nbsp;? A2CI étudie votre besoin et vous propose un accompagnement adapté et sur-mesure.</p>

      <ul class="mb-8 space-y-3 text-sm text-gray-300">
        <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-a2ci-red"></span> Analyse de votre contexte</li>
        <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-a2ci-red"></span> Identification des priorités</li>
        <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-a2ci-red"></span> Proposition et calendrier</li>
      </ul>

      <div class="space-y-6 text-sm mt-10">
        <div class="flex items-center gap-4 group">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-a2ci-red text-white shadow-lg shadow-[#C00000]/20 transition-transform group-hover:scale-110">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase font-bold tracking-wide mb-0.5">Téléphone</p>
            <a href="tel:+33556272367" class="hover:text-a2ci-red text-white transition-colors font-heading font-semibold text-lg">05 56 27 23 67</a>
          </div>
        </div>

        <div class="flex items-center gap-4 group">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-a2ci-red text-white shadow-lg shadow-[#C00000]/20 transition-transform group-hover:scale-110">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase font-bold tracking-wide mb-0.5">Email</p>
            <a href="mailto:contact@a2ci-prevention-incendie.fr" class="hover:text-a2ci-red text-white transition-colors font-medium">contact@a2ci-prevention-incendie.fr</a>
          </div>
        </div>

        <div class="flex items-center gap-4 group">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-a2ci-red text-white shadow-lg shadow-[#C00000]/20 transition-transform group-hover:scale-110">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase font-bold tracking-wide mb-0.5">Bureaux</p>
            <span class="text-gray-300">Parc d'activités du Pays de Langon<br>33210 Mazères</span>
          </div>
        </div>
      </div>
    </div>

    <div class="rounded-2xl bg-white p-6 text-black sm:p-10 shadow-2xl relative overflow-hidden scroll-reveal" data-animate="zoom">
      <div class="absolute top-0 left-0 w-full h-1 bg-a2ci-red"></div>
      <h3 class="font-heading text-2xl font-bold mb-6">Envoyer une demande</h3>

      <form class="space-y-4 text-sm">
        <div>
          <label class="mb-1.5 block text-xs font-bold uppercase text-gray-500">Nom / Prénom</label>
          <input type="text" class="w-full rounded-md border border-gray-200 bg-gray-50 px-4 py-3 focus:border-a2ci-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-a2ci-red/10 transition-all" placeholder="Jean Dupont" />
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-bold uppercase text-gray-500">Entreprise / Collectivité</label>
          <input type="text" class="w-full rounded-md border border-gray-200 bg-gray-50 px-4 py-3 focus:border-a2ci-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-a2ci-red/10 transition-all" placeholder="Nom de votre structure" />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="mb-1.5 block text-xs font-bold uppercase text-gray-500">Email professionnel</label>
            <input type="email" class="w-full rounded-md border border-gray-200 bg-gray-50 px-4 py-3 focus:border-a2ci-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-a2ci-red/10 transition-all" placeholder="votre@email.fr" />
          </div>
          <div>
            <label class="mb-1.5 block text-xs font-bold uppercase text-gray-500">Téléphone</label>
            <input type="tel" class="w-full rounded-md border border-gray-200 bg-gray-50 px-4 py-3 focus:border-a2ci-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-a2ci-red/10 transition-all" placeholder="05 00 00 00 00" />
          </div>
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-bold uppercase text-gray-500">Nature de votre besoin</label>
          <select class="w-full rounded-md border border-gray-200 bg-gray-50 px-4 py-3 focus:border-a2ci-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-a2ci-red/10 transition-all appearance-none">
            <option>Audit / étude de conformité</option>
            <option>Coordination SSI / Ingénierie</option>
            <option>Accompagnement opérationnel (RUS)</option>
            <option>Formations Incendie / 1ers Secours</option>
            <option>Autre demande</option>
          </select>
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-bold uppercase text-gray-500">Votre message</label>
          <textarea rows="4" class="w-full rounded-md border border-gray-200 bg-gray-50 px-4 py-3 focus:border-a2ci-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-a2ci-red/10 transition-all resize-none" placeholder="Précisez votre demande ici..."></textarea>
        </div>
        <button type="submit" class="group relative flex w-full items-center justify-center gap-3 overflow-hidden rounded-md bg-a2ci-red px-6 py-4 text-sm font-bold text-white transition-all hover:bg-[#960606] shadow-lg hover:shadow-[#C00000]/30 active:scale-[0.98]">
          <span class="relative z-10">Envoyer ma demande</span>
          <svg class="relative z-10 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </button>
        <p class="mt-4 text-[10px] text-gray-400 text-center leading-tight">En validant ce formulaire, vous acceptez que les informations saisies soient traitées dans le cadre de votre demande de devis et de la relation commerciale qui peut en découler.</p>
      </form>
    </div>
  </div>
</section>
