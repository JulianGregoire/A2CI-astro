---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mt-[104px] bg-gray-50 border-b border-gray-200 py-3 px-8 text-xs font-medium text-gray-500 w-full z-20 relative">
  <div class="max-w-site mx-auto flex items-center gap-2 overflow-x-auto whitespace-nowrap scrollbar-hide">
    <a href="/" class="hover:text-a2ci-red transition-colors inline-flex items-center gap-1 font-semibold">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
      Accueil
    </a>
    {items.map((item, i) => (
      <>
        <span class="text-gray-300">/</span>
        {i === items.length - 1 ? (
          <span class="text-gray-900 font-bold" aria-current="page">{item.label}</span>
        ) : (
          <a href={item.href} class="hover:text-a2ci-red transition-colors font-semibold">{item.label}</a>
        )}
      </>
    ))}
  </div>
</nav>
