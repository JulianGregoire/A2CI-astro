---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  category: string;
  date: string;
  heroImage: string;
  heroImageAlt: string;
  headline: string;
  headlineAccent: string;
  quote: string;
  categoryColor?: 'red' | 'gray';
}

const {
  title,
  category,
  date,
  heroImage,
  heroImageAlt,
  headline,
  headlineAccent,
  quote,
  categoryColor = 'red',
} = Astro.props;

const badgeClass = categoryColor === 'red'
  ? 'bg-[#C00000]/10 text-[var(--a2ci-red)] border-red-100'
  : 'bg-gray-50 text-gray-500 border-gray-100';
---
<BaseLayout title={title}>
  <Header />
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Blog", href: "/blog" },
    { label: category }
  ]} />

  <article class="pt-40 pb-24">
    <div class="max-w-4xl mx-auto px-8">
      <header class="mb-16 text-center md:text-left">
        <a href="/blog" class="inline-flex items-center gap-2 text-gray-400 hover:text-[var(--a2ci-red)] transition-colors mb-8 text-sm font-bold uppercase tracking-widest">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          Retour au Mag
        </a>
        <div class="flex items-center justify-center md:justify-start gap-4 mb-6">
          <span class={`px-4 py-1 border text-[10px] font-bold uppercase tracking-widest rounded-full ${badgeClass}`}>{category}</span>
          <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">{date}</span>
        </div>
        <h1 class="font-heading text-4xl md:text-6xl font-extrabold text-gray-900 mb-8 leading-tight uppercase tracking-tight" set:html={`${headline} <span class="text-[var(--a2ci-red)]">${headlineAccent}</span>`} />
      </header>

      <div class="rounded-[2.5rem] overflow-hidden mb-16 shadow-2xl">
        <img src={heroImage} alt={heroImageAlt} class="w-full h-auto" />
      </div>

      <div class="article-content max-w-3xl mx-auto">
        <p class="text-xl font-medium text-gray-900 mb-10 leading-relaxed italic border-l-4 border-[var(--a2ci-red)] pl-8">
          "{quote}"
        </p>

        <slot />
      </div>

      <footer class="mt-20 pt-10 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-[var(--a2ci-red)] rounded-full flex items-center justify-center text-white font-bold text-xl uppercase">A</div>
          <div>
            <p class="font-bold text-sm">L'Équipe A2CI</p>
            <p class="text-xs text-gray-400 uppercase tracking-widest">Expertise Prévention</p>
          </div>
        </div>
      </footer>
    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .article-content {
    line-height: 1.8;
    color: #4B5563;
    font-weight: 300;
  }
  .article-content :global(p) {
    margin-bottom: 2rem;
  }
  .article-content :global(h2) {
    font-family: Calibri, Candara, 'Segoe UI', Segoe, Optima, Arial, sans-serif;
    font-weight: 700;
    font-size: 1.875rem;
    color: #111827;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: -0.025em;
  }
</style>
